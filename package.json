{
  "name": "travel",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "setup": "pnpm db:dev && pnpm db:push && pnpm db:seed",
    "db:dev": "pnpm --filter @travel/database db:dev",
    "db:seed": "pnpm --filter @travel/database db:seed",
    "db:generate": "pnpm --filter @travel/database db:generate",
    "db:push": "pnpm --filter @travel/database db:push",
    "db:studio": "pnpm --filter @travel/database db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "docx": "^9.7.1"
  }
}
