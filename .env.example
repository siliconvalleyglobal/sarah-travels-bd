# Database (use `pnpm db:dev` to start local Prisma Postgres — no Docker needed)
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&pgbouncer=true"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
API_URL="http://localhost:4000"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Railway production (example)
# WEB_URL="https://your-web.up.railway.app"
# RAILWAY_RUN_SEED="true"

# Amadeus (Flight API)
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
AMADEUS_ENV="test"

# SSLCommerz
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_SANDBOX=true

# bKash
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_SANDBOX=true

# Nagad
NAGAD_MERCHANT_ID=""
NAGAD_MERCHANT_NUMBER=""
NAGAD_PUBLIC_KEY=""
NAGAD_PRIVATE_KEY=""
NAGAD_SANDBOX=true

# File storage (local dev)
UPLOAD_DIR="./uploads"
